{
  "output_dir": "artifacts/checkpoints/cap-26m-hn-adapt",
  "tokenizer_dir": "artifacts/tokenizers/cap-bytebpe",
  "dataset": {
    "name": "open-index/hacker-news",
    "subset": "default",
    "split": "train",
    "streaming": true,
    "include_comments": true,
    "include_stories": true,
    "min_comment_chars": 120,
    "min_story_title_chars": 20,
    "year_start": 2022,
    "year_end": 2025
  },
  "sequence_length": 256,
  "micro_batch_size": 8,
  "gradient_accumulation_steps": 8,
  "total_tokens": 30000000,
  "warmup_steps": 150,
  "learning_rate": 0.0001,
  "min_learning_rate": 0.00001,
  "weight_decay": 0.1,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_epsilon": 1e-08,
  "grad_clip": 1.0,
  "eval_every_steps": 250,
  "eval_batches": 20,
  "save_every_steps": 250,
  "max_train_examples": 250000,
  "seed": 42,
  "use_gradient_checkpointing": true
}
